# Signing credentials live in .envrc.local (not committed to git).
# Create it the first time you use this directory:
#
#   cat > ops/.envrc.local << 'EOF'
#   export OSX_SIGN_HOST=user@macos-signing-host
#   export WIN_SIGN_HOST=user@hsm-host   # ProxyJump via deployer in ~/.ssh/config
#   export GPG_USER=your-key-id-or-email # optional
#   EOF

if [ ! -f "$PWD/.envrc.local" ]; then
  echo "ops/.envrc.local not found — signing env vars will not be set."
  echo "Create it with:"
  echo "  cat > ops/.envrc.local << 'EOF'"
  echo "  export OSX_SIGN_HOST=user@macos-signing-host"
  echo "  export WIN_SIGN_HOST=user@hsm-host"
  echo "  export GPG_USER=your-key-id-or-email"
  echo "  EOF"
fi

source_env_if_exists .envrc.local

use flake ..#ops
